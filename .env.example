APP_NAME=Virtus et Veritas Engine
APP_ENV=development
API_PREFIX=/api/v1

FRONTEND_PORT=3000
BACKEND_PORT=8000

NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
CORS_ORIGINS=http://localhost:3000

POSTGRES_DB=vve_engine
POSTGRES_USER=vve_user
POSTGRES_PASSWORD=change_me_secure_password
DATABASE_URL=postgresql+psycopg://vve_user:change_me_secure_password@postgres:5432/vve_engine

JWT_SECRET=change_me_super_secret_key
JWT_EXPIRES_MINUTES=1440
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
API_ENCRYPTION_KEY=change_me_generate_a_real_fernet_key

SEED_ORGANIZATION_NAME=Virtus et Veritas Academy
SEED_ORGANIZATION_SLUG=virtus-et-veritas-academy
SEED_ADMIN_NAME=Leonardo Elias
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change_me_admin_password

# Provedor de IA padrao do sistema (usado quando um projeto nao escolhe um
# provedor especifico na criacao). Cada projeto pode sobrepor esse padrao
# individualmente. Valores aceitos: openai | gemini
AI_PROVIDER=openai

# OpenAI permanece configurado para TTS (audio_service) e disponivel como
# provedor de texto escolhivel por projeto (ai_provider=openai).
OPENAI_PROVIDER_NAME=OpenAI
OPENAI_API_KEY=change_me_openai_api_key
OPENAI_DEFAULT_MODEL=gpt-5-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
OPENAI_TTS_FORMAT=mp3

# Gemini: provedor de texto adicional, escolhivel por projeto (ai_provider=gemini).
GEMINI_PROVIDER_NAME=Gemini
GEMINI_API_KEY=change_me_gemini_api_key
GEMINI_DEFAULT_MODEL=gemini-2.5-flash
GEMINI_MAX_OUTPUT_TOKENS=8192
GEMINI_TIMEOUT_SECONDS=180

ELEVENLABS_API_KEY=
ELEVENLABS_TTS_MODEL=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
VIDEO_PROVIDER=mock
VIDEO_DEFAULT_RESOLUTION=1080p
VIDEO_DEFAULT_FORMAT=mp4
HEYGEN_API_KEY=
HEYGEN_API_BASE_URL=https://api.heygen.com
HEYGEN_DEFAULT_AVATAR_ID=
HEYGEN_WEBHOOK_SECRET=
HEYGEN_POLL_INTERVAL_SECONDS=15

DID_API_KEY=
DID_API_BASE_URL=https://api.d-id.com
DID_DEFAULT_SOURCE_IMAGE_URL=

SYNC_API_KEY=
SYNC_API_BASE_URL=https://api.sync.so/v2
SYNC_DEFAULT_SOURCE_VIDEO_URL=
SYNC_DEFAULT_SOURCE_IMAGE_URL=
SYNC_DEFAULT_MODEL=lipsync-2

# URL publica onde o backend e acessivel (usada para montar links assinados
# de audio que provedores externos como Sync Labs precisam buscar via HTTP).
PUBLIC_BASE_URL=http://localhost:8000

STORAGE_DRIVER=local
STORAGE_PATH=/app/storage
MAX_UPLOAD_SIZE_MB=100
